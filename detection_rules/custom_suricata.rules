# Custom Suricata Network Signatures
# MITRE ATT&CK mapped — SOC Home Lab
# Deploy to: /etc/suricata/rules/custom_suricata.rules

# ============================================================
# T1046 - Network Service Discovery (Nmap scan detection)
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"CUSTOM - T1046 Nmap SYN Scan Detected";
  flags:S;
  threshold: type both, track by_src, count 100, seconds 5;
  classtype:network-scan;
  sid:9000001; rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"CUSTOM - T1046 Nmap NULL Scan Detected";
  flags:0;
  classtype:network-scan;
  sid:9000002; rev:1;
)

# ============================================================
# T1110 - Brute Force (SSH)
# ============================================================
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (
  msg:"CUSTOM - T1110 SSH Brute Force Attempt";
  flow:to_server,established;
  content:"SSH-";
  threshold: type both, track by_src, count 10, seconds 60;
  classtype:attempted-admin;
  sid:9000010; rev:1;
)

# ============================================================
# T1071.001 - C2 over HTTP (Metasploit Meterpreter UA)
# ============================================================
alert http $HOME_NET any -> $EXTERNAL_NET any (
  msg:"CUSTOM - T1071.001 Possible Meterpreter C2 User-Agent";
  http.user_agent;
  content:"Mozilla/4.0 (compatible; MSIE 6.0";
  pcre:"/Mozilla\/4\.0.*MSIE 6\.0.*Windows NT 5\.1$/";
  classtype:trojan-activity;
  sid:9000020; rev:1;
)

# ============================================================
# T1048 - Exfiltration Over Alternative Protocol (DNS)
# ============================================================
alert dns $HOME_NET any -> any 53 (
  msg:"CUSTOM - T1048 Possible DNS Exfiltration - Oversized Query";
  dns.query;
  byte_test:1,>,50,0,relative;
  threshold: type both, track by_src, count 20, seconds 60;
  classtype:policy-violation;
  sid:9000030; rev:1;
)

# ============================================================
# T1190 - Exploit Public-Facing App (generic payload attempt)
# ============================================================
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (
  msg:"CUSTOM - T1190 HTTP Request with Shell Metacharacters";
  http.uri;
  pcre:"/(;|\||\`|>|<|\$\(|%0a|%0d)/i";
  classtype:web-application-attack;
  sid:9000040; rev:1;
)
